#!/usr/bin/env bash
# jmemviz — thin wrapper around the jmemviz fat jar.
#
# Usage (same as the jar):
#   ./jmemviz [command] [args...]
#
# Commands:
#   serve  [trace.json] [port]
#   preprocess <input.java> [output.java]
#   help | -h | --help
#
# The jar is expected at target/jmemviz-*.jar relative to this script.
# Run 'mvn package' (or 'mvn package -DskipTests') first.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Find the shaded fat jar; exclude the original- copy produced by maven-shade.
JAR="$(find "$SCRIPT_DIR/target" -maxdepth 1 -name 'jmemviz-*.jar' \
       ! -name 'original-*' 2>/dev/null | head -1)"

if [ -z "$JAR" ]; then
    echo "[jmemviz] jar not found in $SCRIPT_DIR/target/" >&2
    echo "[jmemviz] Build it first:" >&2
    echo "    mvn package -DskipTests" >&2
    exit 1
fi

exec java -jar "$JAR" "$@"
